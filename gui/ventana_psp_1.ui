  <property name="styleSheet">
   <string notr="true">/* =========================
   ESTILO GENERAL
   ========================= */
QMainWindow {
    background-color: #F2FBFA; /* azul-verdoso muy claro */
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;;
    font-size: 16px;
    color: #2F4F4F;
}

QWidget#centralwidget {
    background-color: transparent;
}

/* =========================
   MENU BAR
   ========================= */
QMenuBar {
    background-color: #D9F3F0; /* verde-azul suave */
    padding: 6px;
    border: none;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 12px;
    border-radius: 8px;
}

QMenuBar::item:selected {
    background-color: #AEE6E1;
}

/* =========================
   MENUS DESPLEGABLES
   ========================= */
QMenu {
    background-color: #FFFFFF;
    border: 1px solid #BFEAE5;
    border-radius: 10px;
    padding: 6px;
}

QMenu::item {
    padding: 8px 20px;
    border-radius: 6px;
}

QMenu::item:selected {
    background-color: #E6FAF8;
}

/* =========================
   LABELS
   ========================= */
QLabel {
    color: #2F4F4F;
    font-size: 16px;
}

/* Puedes usar este para títulos (opcional) */
QLabel#label {
    font-size: 20px;
    font-weight: bold;
    color: #1F7A7A;
}

/* =========================
   INPUT (QLineEdit)
   ========================= */
QLineEdit {
    background-color: #FFFFFF;
    border: 1.5px solid #BFEAE5;
    border-radius: 10px;
    padding: 8px;
    color: #2F4F4F;
}

QLineEdit:focus {
    border: 2px solid #4DB6AC; /* verde aqua */
    background-color: #F5FFFE;
}

/* =========================
   BOTONES PRINCIPALES
   ========================= */
QPushButton {
    background-color: #B2EBF2; /* azul claro */
    border: none;
    border-radius: 12px;
    padding: 10px 16px;
    color: #1F3F3F;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #80DEEA;
}

QPushButton:pressed {
    background-color: #4DD0E1;
}

/* =========================
   BOTÓN SECUNDARIO
   ========================= */
QPushButton#pushButton_2 {
    background-color: #C8E6C9; /* verde claro */
}

QPushButton#pushButton_2:hover {
    background-color: #A5D6A7;
}

/* =========================
   VARIACIÓN BOTONES (opcionales)
   ========================= */
QPushButton#pushButton_3 {
    background-color: #AED581;
}

QPushButton#pushButton_4 {
    background-color: #81D4FA;
}

QPushButton#pushButton_5 {
    background-color: #80CBC4;
}

/* =========================
   STATUS BAR
   ========================= */
QStatusBar {
    background-color: #D9F3F0;
    color: #2F4F4F;
}

/* =========================
   SCROLLBAR (EXTRA PRO)
   ========================= */
QScrollBar:vertical {
    background: #E0F7F5;
    width: 10px;
    margin: 2px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: #80CBC4;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: #4DB6AC;
}

/* =========================
   TOOLTIP
   ========================= */
QToolTip {
    background-color: #FFFFFF;
    color: #2F4F4F;
    border: 1px solid #BFEAE5;
    padding: 6px;
    border-radius: 6px;
}</string>
